# Backend API URL (your AWS API Gateway endpoint or localhost for dev)
NEXT_PUBLIC_API_URL=https://your-api-gateway-url.execute-api.us-east-1.amazonaws.com

# Admin page password (client-side, keep it simple — real auth is the server-side ADMIN_API_KEY)
NEXT_PUBLIC_ADMIN_PASSWORD=""

# Passed server-side only to admin API routes
ADMIN_API_KEY=""
NEXTAUTH_URL=http://lwocalhost:3000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=